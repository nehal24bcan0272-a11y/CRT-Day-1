//Problem 5 
//function overloading

#include<iostream>
using namespace std;


int add(int a,int b){
    return a + b;
}

float add(float a,float b,float c,float d){
    return a + b +c +d;
}

int main(){
    cout<<add(5,2)<<"\n";
    cout<<add(5,2,3)<<"\n";
    cout<<add(5.5,2.3,5.5,7.9);
    
}


